APP_NAME="WhatsApp AI Agent"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com
APP_TIMEZONE=Africa/Casablanca

LOG_CHANNEL=stack
LOG_LEVEL=debug
LOG_DEPRECATIONS_CHANNEL=null

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=wa_agent
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# NVIDIA AI Services
NVIDIA_API_URL=https://integrate.api.nvidia.com
NVIDIA_API_KEY=nvapi-your-key-here
NVIDIA_LLM_MODEL=meta/llama-3.1-405b-instruct
NVIDIA_STT_MODEL=nvidia/parakeet-rnnt-1.1b
NVIDIA_VISION_MODEL=microsoft/kosmos-2

# Meta WhatsApp Cloud API
META_API_VERSION=v18.0
META_ACCESS_TOKEN=EAAXXXXXXXXXXXXXXXXX
META_PHONE_NUMBER_ID=123456789012345
META_BUSINESS_ACCOUNT_ID=123456789012345
META_VERIFY_TOKEN=your_webhook_verify_token_here

# Alternative Twilio Config (if using Twilio)
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_NUMBER=+14155238886

# Product Catalog
PRODUCTS_CATALOG_FILE=storage/app/products.json
PRODUCTS_DEFAULT_CURRENCY=MAD

# Admin Notifications
ADMIN_EMAIL=admin@yourstore.ma
ADMIN_PHONE=+212600000000

# Maintenance Mode
MAINTENANCE_MODE=false
